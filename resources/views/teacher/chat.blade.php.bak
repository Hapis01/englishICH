@push('scripts')
<script>
    // Open Add Student Modal
    function openAddStudentModal() {
        const modal = document.getElementById('addStudentModal');
        modal.classList.remove('hidden');
        loadStudentsForChat();
    }

    // Close Add Student Modal
    function closeAddStudentModal() {
        const modal = document.getElementById('addStudentModal');
        modal.classList.add('hidden');
    }

    // Load all students for chat
    function loadStudentsForChat() {
        fetch('{{ route('teacher.chat.students') }}')
            .then(response => response.json())
            .then(data => {
                const studentsList = document.getElementById('studentsList');
                if (data.success && data.data.length > 0) {
                    studentsList.innerHTML = '';
                    data.data.forEach(student => {
                        const studentDiv = document.createElement('div');
                        studentDiv.className = 'p-3 border border-gray-200 rounded-lg hover:bg-blue-50 cursor-pointer transition';
                        studentDiv.innerHTML = `
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 rounded-full flex-shrink-0 ${student.avatar ? 'overflow-hidden' : 'bg-[#10B981] flex items-center justify-center text-white font-semibold text-sm'}">
                                    ${student.avatar ? `<img src="/storage/${student.avatar}" alt="${student.name}" class="w-full h-full object-cover">` : student.name.charAt(0)}
                                </div>
                                <div class="flex-1">
                                    <p class="font-semibold text-gray-900 text-sm">${student.name}</p>
                                    <p class="text-xs text-gray-500">${student.email}</p>
                                </div>
                            </div>
                        `;
                        studentDiv.onclick = () => startConversation(${student.id});
                        studentsList.appendChild(studentDiv);
                    });
                } else {
                    studentsList.innerHTML = '<p class="text-center text-gray-500 text-sm py-8">No students available</p>';
                }
            })
            .catch(error => {
                console.error('Error loading students:', error);
                document.getElementById('studentsList').innerHTML = '<p class="text-center text-red-500 text-sm py-8">Error loading students</p>';
            });
    }

    // Start conversation with a student
    function startConversation(studentId) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '{{ route('teacher.chat.create') }}';
        form.innerHTML = `
            @csrf
            <input type="hidden" name="student_id" value="${studentId}">
        `;
        document.body.appendChild(form);
        form.submit();
    }

    // Load conversation
    function loadConversation(conversationId) {
        window.location.href = `{{ route('teacher.chat') }}?conversation_id=${conversationId}`;
    }

    // Scroll to bottom of messages
    function scrollToBottom() {
        const container = document.getElementById('messagesContainer');
        if (container) {
            container.scrollTop = container.scrollHeight;
        }
    }

    // Auto-scroll on page load
    document.addEventListener('DOMContentLoaded', function() {
        scrollToBottom();
        
        // Mark messages as read
        @if($selectedConversation)
            fetch(`{{ route('teacher.chat') }}?conversation_id={{ $selectedConversation->id }}&mark_read=1`)
                .catch(error => console.error('Error marking messages as read:', error));
        @endif
    });

    // Attachment file name display
    document.getElementById('attachmentInput')?.addEventListener('change', function(e) {
        const fileName = e.target.files[0]?.name;
        const attachmentName = document.getElementById('attachmentName');
        if (fileName && attachmentName) {
            attachmentName.textContent = `📎 ${fileName}`;
        } else if (attachmentName) {
            attachmentName.textContent = '';
        }
    });

    // Search conversations
    document.getElementById('searchConversation')?.addEventListener('input', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const conversations = document.querySelectorAll('.conversation-item');
        
        conversations.forEach(conversation => {
            const studentName = conversation.querySelector('h4').textContent.toLowerCase();
            if (studentName.includes(searchTerm)) {
                conversation.style.display = '';
            } else {
                conversation.style.display = 'none';
            }
        });
    });

    // Auto-refresh messages every 10 seconds
    @if($selectedConversation)
        setInterval(function() {
            fetch(`{{ route('teacher.chat.messages', $selectedConversation) }}`)
                .then(response => response.json())
                .then(data => {
                    // Update messages if new messages exist
                    if (data.messages && data.messages.length > 0) {
                        const container = document.getElementById('messagesContainer');
                        const currentHeight = container.scrollHeight;
                        const isScrolledToBottom = container.scrollTop + container.clientHeight >= currentHeight - 50;
                        
                        // Update messages (simplified - in production use proper DOM manipulation)
                        if (isScrolledToBottom) {
                            scrollToBottom();
                        }
                    }
                })
                .catch(error => console.error('Error fetching messages:', error));
        }, 10000);
    @endif

    // Auto-resize textarea
    const messageInput = document.getElementById('messageInput');
    if (messageInput) {
        messageInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });
    }

    // Submit form on Ctrl+Enter
    if (messageInput) {
        messageInput.addEventListener('keydown', function(e) {
            if (e.ctrlKey && e.key === 'Enter') {
                document.getElementById('messageForm').submit();
            }
        });
    }
</script>
@endpush